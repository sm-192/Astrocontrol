# ─────────────────────────────────────────────
#  AstroControl — .gitignore
# ─────────────────────────────────────────────

# ── Node.js ──────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── Ambiente / Runtime ────────────────────────
.env
.env.*
*.local

# ── Logs ─────────────────────────────────────
logs/
*.log

# ── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Ferramentas de IA / editor ───────────────
.summary_files/
.vscode/settings.json
.vscode/*.code-snippets
*.swp
*.swo
*~

# ── Sistema operacional ───────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Arquivos temporários / rascunhos ─────────
teste
WORKING_NOTES.md
